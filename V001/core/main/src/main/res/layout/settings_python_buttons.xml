<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/btnStartPythonApp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🐍 Python App (main.pyc)"
        android:textSize="16sp"
        android:backgroundTint="#4caf50"
        android:textColor="#ffffff"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnStartPythonService"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚙️ Python Service (service/main.pyc)"
        android:textSize="16sp"
        android:backgroundTint="#2196f3"
        android:textColor="#ffffff" />
        
    <Button
        android:id="@+id/btnStartPythonAppService"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎾 Python App (service/main.pyc)"
        android:textSize="16sp"
        android:backgroundTint="#2196f3"
        android:textColor="#ffffff" />

</LinearLayout>