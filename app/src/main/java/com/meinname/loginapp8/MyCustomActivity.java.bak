    public static void showLog(String tag, String message) {
        PythonService.showLog(tag, message);
    }

    private boolean checkPythonAvailability() {
        return checkPythonNativeLibs();
    }

    private boolean checkPythonNativeLibs() {
        String nativeLibDir = getApplicationInfo().nativeLibraryDir;
        
        String[] requiredLibs = {
            "libpython3.11.so",
            "libmain.so",
            "libpybundle.so"
        };
        
        for (String lib : requiredLibs) {
            File libFile = new File(nativeLibDir, lib);
            if (!libFile.exists()) {
                Log.w(TAG, "Fehlende native Bibliothek: " + lib);
                return false;
            }
        }
        
        showLog(TAG, "Alle nativen Python-Bibliotheken gefunden in: " + nativeLibDir);
        return true;
    }

    private void showModeSelectionDialog() {
        // Dialog-Layout laden
        View dialogView = LayoutInflater.from(this).inflate(R.layout.dialog_mode_selection, null);
        
        
        // Views aus Dialog-Layout
        RadioButton dialogRbPython = dialogView.findViewById(R.id.rbPython);
        
        RadioButton dialogRbTerminal = dialogView.findViewById(R.id.rbTerminal);
        
        RadioGroup dialogRadioGroup = dialogView.findViewById(R.id.radioGroup);
        
        TextView dialogTvStatus = dialogView.findViewById(R.id.tvStatus);
        
        TextView dialogTvHint = dialogView.findViewById(R.id.tvHint);
        
        Button btnPositive = dialogView.findViewById(R.id.btnPositive);
        
        Button btnNegative = dialogView.findViewById(R.id.btnNegative);
        
        // Status setzen
        if (pythonAvailable) {
            dialogTvStatus.setText("✅ Python/Kivy ist verfügbar.");
            dialogRbPython.setVisibility(View.VISIBLE);
        } else {
            dialogTvStatus.setText("❌ Python wurde NICHT gefunden! Nur Terminal verfügbar.");
            dialogRbPython.setVisibility(View.GONE);
            dialogTvHint.setVisibility(View.VISIBLE);
            dialogTvHint.setText("💡 Tipp: Führe 'buildozer -v android debug' aus,\num den Python-Bundle zu erstellen.");
        }
        
        // Standard-Auswahl
        if (pythonAvailable) {
            dialogRbPython.setChecked(true);
        } else {
            dialogRbTerminal.setChecked(true);
        }
        
        // Dialog erstellen
        AlertDialog.Builder builder = new AlertDialog.Builder(this);
        builder.setView(dialogView);
        builder.setCancelable(false);
        
        AlertDialog dialog = builder.create();
        
        // Animation hinzufügen (Android 21+)
        if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.LOLLIPOP) {
            dialog.getWindow().setWindowAnimations(R.style.DialogAnimation);
        }
        
        // Positive Button (Start)
        btnPositive.setOnClickListener(v -> {
            int selectedId = dialogRadioGroup.getCheckedRadioButtonId();
            
            // 1. Zuerst Dialog schließen
            dialog.dismiss();
            
            // 2. Dann Aktionen ausführen (mit kurzer Verzögerung)
            new android.os.Handler().postDelayed(() -> {
                if (pythonAvailable && selectedId == R.id.rbPython) {
                
                    startAllThree();
                    //startPythonMode();
                    
                } else {
                    startReTerminalMode();
                }
            }, DELAY); // Wartet auf Exit-Animation
        });
        
        btnNegative.setOnClickListener(v -> {
            // 1. Zuerst Dialog schließen
            dialog.dismiss();
            
            // 2. Dann Activity beenden
            new android.os.Handler().postDelayed(() -> {
                finish();
            }, DELAY);
        });
        
        dialog.show();
    }
    
    /**
     * Startet den Python-Modus
     */
    private void startPythonMode() {
        showLog(TAG, "Python-Modus starten ....");
        
        if (pythonAvailable) {
            Intent intent = new Intent(this, org.kivy.android.PythonActivity.class);
            
            Toast.makeText(this, "Python wird gestartet ...", Toast.LENGTH_LONG).show();
            startActivity(intent);
            finish();
        } else {
            Toast.makeText(this, "Python-Bibliotheken fehlen!", Toast.LENGTH_LONG).show();
        }
    }
    
    private void startPythonThread() {
        showLog(TAG, "Python-Modus gewählt - Starte mit Thread");
        
        // ★ Thread für die Ausführung
        new Thread(new Runnable() {
            @Override
            public void run() {
                try {
                    // 1. Kurze Verzögerung (optional)
                    Thread.sleep(100);
                    
                    // 2. Intent erstellen
                    Intent intent = new Intent(MyCustomActivity.this, org.kivy.android.PythonActivity.class);
                    
                    // 3. Zusätzliche Flags (optional)
                    intent.setFlags(Intent.FLAG_ACTIVITY_NEW_TASK | Intent.FLAG_ACTIVITY_CLEAR_TASK);
                    
                    // 4. Auf UI-Thread wechseln für startActivity
                    runOnUiThread(new Runnable() {
                        @Override
                        public void run() {
                            try {
                                Toast.makeText(MyCustomActivity.this, "Python wird gestartet ...", Toast.LENGTH_LONG).show();
                                
                                startActivity(intent);
                                finish();
                                showLog(TAG, "✅ Python gestartet");
                            } catch (Exception e) {
                                showLog(TAG, "❌ Fehler beim Start: Python " + e.getMessage());
                            }
                        }
                    });
                    
                } catch (InterruptedException e) {
                    showLog(TAG, "❌ Thread unterbrochen: " + e.getMessage());
                    Thread.currentThread().interrupt();
                } catch (Exception e) {
                    showLog(TAG, "❌ Fehler: " + e.getMessage());
                }
            }
        }).start();  // ★ Thread starten
    }
    
    private void startReTerminalModeBack() {
        showLog(TAG, "Terminal-Modus gewählt - Starte mit Thread Back");
        
        new Thread(() -> {
            try {
                // 1. Activity starten
                runOnUiThread(() -> {
                    Intent intent = new Intent(MyCustomActivity.this, 
                        com.rk.terminal.ui.activities.terminal.MainActivity.class);
                    startActivity(intent);
                });
                
                // 2. Kurz warten
                Thread.sleep(5000);
                
                showLog(TAG, "✅ ReTerminal gestartet, Activity im Hintergrund");
                
            } catch (Exception e) {
                showLog(TAG, "❌ Fehler: " + e.getMessage());
            }
        }).start();
    }
    
    private void startReTerminalMode() {
        showLog(TAG, "Terminal-Modus gewählt");
        Intent intent = new Intent(MyCustomActivity.this, 
            com.rk.terminal.ui.activities.terminal.MainActivity.class);
        startActivity(intent);
        finish();
    }
    
    private void startReTerminalThread() {
        showLog(TAG, "Terminal-Modus gewählt - Starte mit Thread");
        
        // ★ Thread für die Ausführung
        new Thread(new Runnable() {
            @Override
            public void run() {
                try {
                    // 1. Kurze Verzögerung (optional)
                    Thread.sleep(100);
                    
                    // 2. Intent erstellen
                    Intent intent = new Intent(MyCustomActivity.this, 
                        com.rk.terminal.ui.activities.terminal.MainActivity.class);
                    
                    // 3. Zusätzliche Flags (optional)
                    intent.setFlags(Intent.FLAG_ACTIVITY_NEW_TASK | Intent.FLAG_ACTIVITY_CLEAR_TASK);
                    
                    // 4. Auf UI-Thread wechseln für startActivity
                    runOnUiThread(new Runnable() {
                        @Override
                        public void run() {
                            try {
                                startActivity(intent);
                                finish();
                                showLog(TAG, "✅ ReTerminal gestartet");
                            } catch (Exception e) {
                                showLog(TAG, "❌ Fehler beim Start: " + e.getMessage());
                            }
                        }
                    });
                    
                } catch (InterruptedException e) {
                    showLog(TAG, "❌ Thread unterbrochen: " + e.getMessage());
                    Thread.currentThread().interrupt();
                } catch (Exception e) {
                    showLog(TAG, "❌ Fehler: " + e.getMessage());
                }
            }
        }).start();  // ★ Thread starten
    }
    
    
    
    private void startReTerminalProcess() {
    showLog(TAG, "🚀 startReTerminalProcess() AUFGERUFEN!");  // ★ Erste Log
    showLog(TAG, "Terminal-Modus gewählt - Starte mit ProcessBuilder");
    
    new Thread(new Runnable() {
        @Override
        public void run() {
            showLog(TAG, "🔄 Thread gestartet");
            
            try {
                // 1. Prozess starten
                ProcessBuilder pb = new ProcessBuilder(
                    "am", "start",
                    "-n", "com.rk.terminal/.ui.activities.terminal.MainActivity",
                    "--activity-clear-task",
                    "--activity-new-task",
                    "--activity-multiple-task"
                );
                
                showLog(TAG, "📦 ProcessBuilder erstellt");
                
                // 2. Separate Prozess-Gruppe
                pb.redirectErrorStream(true);
                Process process = pb.start();
                
                showLog(TAG, "✅ Prozess gestartet");
                
                // 3. Prozess-ID auslesen
                int pid = android.os.Process.myPid();
                showLog(TAG, "✅ ReTerminal gestartet (ProcessBuilder)");
                showLog(TAG, "   Main Process PID: " + pid);
                showLog(TAG, "   Child Process PID: " + getChildProcessId(process));
                
                // 4. Prozess nicht blockieren
                process.waitFor(1000, java.util.concurrent.TimeUnit.MILLISECONDS);
                showLog(TAG, "⏳ Prozess waitFor abgeschlossen");
                
            } catch (Exception e) {
                showLog(TAG, "❌ Fehler: " + e.getMessage());
                e.printStackTrace();
            }
        }
    }).start();
    
    showLog(TAG, "🏁 startReTerminalProcess() beendet");
}
    
    private int getChildProcessId(Process process) {
        try {
            java.lang.reflect.Field field = process.getClass().getDeclaredField("pid");
            field.setAccessible(true);
            return field.getInt(process);
        } catch (Exception e) {
            return -1;
        }
    }

        
        
