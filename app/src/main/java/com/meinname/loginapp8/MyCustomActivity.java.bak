    private void startBackgroundSetup() {
        new Thread(() -> {
            try {
                showLog(TAG, "Starte Hintergrund-Entpacken...");
                
                File appDir = new File(getFilesDir(), "app");
                appDir.mkdirs();
                
                PythonUtil.unpackAsset(this, "private", appDir, true);
                showLog(TAG, "✅ private.tar entpackt");
                
                PythonUtil.unpackPyBundle(this, 
                    getApplicationInfo().nativeLibraryDir + "/libpybundle", 
                    appDir, false);
                showLog(TAG, "✅ libpybundle entpackt");
                
                File libDir = new File(appDir, "lib");
                if (!libDir.exists()) {
                    libDir.mkdirs();
                    String nativeLibDir = getApplicationInfo().nativeLibraryDir;
                    
                    File sourceSo = new File(nativeLibDir, "libpybundle.so");
                    File targetSo = new File(libDir, "libpybundle.so");
                    if (sourceSo.exists()) {
                        copyFile(sourceSo, targetSo);
                        showLog(TAG, "✅ libpybundle.so kopiert");
                    }
                    
                    File sourcePython = new File(nativeLibDir, "libpython3.11.so");
                    File targetPython = new File(libDir, "libpython3.11.so");
                    if (sourcePython.exists()) {
                        copyFile(sourcePython, targetPython);
                        showLog(TAG, "✅ libpython3.11.so kopiert");
                    }
                }
                
                showLog(TAG, "✅ Hintergrund-Setup abgeschlossen");
            } catch (Exception e) {
                showLog(TAG, "❌ Hintergrund-Fehler: " + e.getMessage());
            }
        }).start();
        
    }
    
    private void copyFile(File source, File dest) throws IOException {
        FileInputStream fis = new FileInputStream(source);
        FileOutputStream fos = new FileOutputStream(dest);
        byte[] buffer = new byte[8192];
        int length;
        while ((length = fis.read(buffer)) > 0) {
            fos.write(buffer, 0, length);
        }
        fis.close();
        fos.close();
    }
}